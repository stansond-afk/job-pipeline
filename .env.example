# .env.example — copy to .env (which is gitignored) and fill in.
# The setup wizard writes this file for you; this is what each value means.
#
# DO NOT commit .env. Anything in here either grants access to a paid service
# or identifies private cloud resources.

# ─────────────────────────────────────────────────────────────────────────
# Cloudflare — required for the deployed dashboard + Worker write surface.
# ─────────────────────────────────────────────────────────────────────────

# API token with permissions: D1 (read/write), Workers Scripts (edit),
# Workers Routes (edit). Create at:
#   https://dash.cloudflare.com/profile/api-tokens → Create Token
# The wizard guides you through this with screenshots.
CLOUDFLARE_API_TOKEN=

# Your Cloudflare account ID. Find it on the right sidebar of any
# zone/worker page in the dashboard, or via `wrangler whoami`.
CLOUDFLARE_ACCOUNT_ID=

# D1 database details. The wizard creates the database and fills these in.
D1_DATABASE_NAME=job-pipeline-events
D1_DATABASE_ID=

# Cloudflare Access (Zero Trust) — protects your deployed dashboard.
# Wizard creates the Access application and captures these values.
ACCESS_AUD=
ACCESS_TEAM_DOMAIN=

# Worker name (used as the deploy URL prefix). Derived from your name by
# the wizard; override if you want a custom subdomain.
WORKER_NAME=job-pipeline

# Wrangler compatibility date. Bump occasionally (set to today's date).
WRANGLER_COMPAT_DATE=2026-05-24

# ─────────────────────────────────────────────────────────────────────────
# USAJobs API — optional. Get one (free, 2 min) at:
#   https://developer.usajobs.gov/apirequest/
# Skip if you don't want federal jobs.
# ─────────────────────────────────────────────────────────────────────────

USAJOBS_API_KEY=
USAJOBS_USER_AGENT=

# ─────────────────────────────────────────────────────────────────────────
# Tailored files watch directory — where the dashboard auto-discovers
# your tailored resumes/cover letters when you click Apply. Defaults to
# ~/Downloads. Override in profile.yaml or here.
# ─────────────────────────────────────────────────────────────────────────

# TAILORED_FILES_DIR=~/Downloads
