# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/

# SQLite database — local binary state, never commit.
# The text-format SQL dump (jobs.sql.gz) IS committed as the source of
# truth; the binary is regenerated from it on each workflow run.
db/*.db
db/*.db-journal
db/*.db-wal
db/*.db-shm
!db/jobs.sql.gz

# Personal config — generated by the setup wizard from the .example files.
# These contain user-specific information (name, target locations, etc.)
# and SHOULD NEVER be committed when forking for an individual user.
config/profile.yaml
config/scoring.yaml
config/geo_patterns.yaml
config/search_queries.csv
config/targets.csv

# Personal Cloudflare config — generated by the wizard from wrangler.template.jsonc.
# Contains the user's D1 UUID + Access AUD.
wrangler.jsonc

# Generated dashboard — regenerated on every run; commit only if you want
# the deployed Cloudflare Worker to serve the latest data (similar pattern
# to the solongo-jobs original).
# dashboard/index.html
# Uncomment the line above to exclude the generated dashboard from git.

# Env files (contain secrets — API keys, etc.)
.env
.env.local

# Editor / OS
.vscode/
.idea/
.DS_Store
*.swp

# Wrangler local dev cache (generated by wrangler)
.wrangler/
